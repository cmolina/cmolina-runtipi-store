{
  "schemaVersion": 2,
  "services": [
    {
      "name": "dawarich_redis",
      "image": "redis:7.4-alpine",
      "isMain": false
    },
    {
      "name": "dawarich_db",
      "image": "postgis/postgis:17-3.5-alpine",
      "isMain": false,
      "environment": [
        { "key": "POSTGRES_USER", "value": "postgres" },
        { "key": "POSTGRES_PASSWORD", "value": "${POSTGRES_PASSWORD}" },
        { "key": "POSTGRES_DB", "value": "dawarich_production" }
      ]
    },
    {
      "name": "dawarich_app",
      "image": "freikin/dawarich:1.3.1",
      "isMain": true,
      "internalPort": 3000,
      "entrypoint": "web-entrypoint.sh",
      "command": ["bash", "-c", "bundle exec rails runner 'email = ENV[\"ADMIN_EMAIL\"].to_s.strip; password = ENV[\"ADMIN_PASSWORD\"].to_s.strip; if email.present? && password.present?; User.create!(email: email, password: password, password_confirmation: password, admin: true, status: :active, active_until: 100.years.from_now) unless User.exists?(email: email); User.find_by(email: \"demo@dawarich.app\")&.destroy!; end' && exec bin/rails server -p 3000 -b ::"],
      "stdinOpen": true,
      "tty": true,
      "environment": [
        { "key": "RAILS_ENV", "value": "production" },
        { "key": "REDIS_URL", "value": "redis://dawarich_redis:6379" },
        { "key": "DATABASE_HOST", "value": "dawarich_db" },
        { "key": "DATABASE_PORT", "value": "5432" },
        { "key": "DATABASE_USERNAME", "value": "postgres" },
        { "key": "DATABASE_PASSWORD", "value": "${POSTGRES_PASSWORD}" },
        { "key": "DATABASE_NAME", "value": "dawarich_production" },
        { "key": "APPLICATION_HOSTS", "value": "${APP_DOMAIN},${APP_LOCAL_DOMAIN},${APP_HOST}:${APP_PORT}" },
        { "key": "TIME_ZONE", "value": "${TIME_ZONE}" },
        { "key": "APPLICATION_PROTOCOL", "value": "http" },
        { "key": "SECRET_KEY_BASE", "value": "${SECRET_KEY_BASE}" },
        { "key": "ADMIN_EMAIL", "value": "${ADMIN_EMAIL}" },
        { "key": "ADMIN_PASSWORD", "value": "${ADMIN_PASSWORD}" },
        { "key": "RAILS_LOG_TO_STDOUT", "value": "true" },
        { "key": "SELF_HOSTED", "value": "true" },
        { "key": "STORE_GEODATA", "value": "true" },
        { "key": "PHOTON_API_HOST", "value": "${PHOTON_API_HOST}" },
        { "key": "PHOTON_API_KEY", "value": "${PHOTON_API_KEY}" },
        { "key": "PHOTON_API_USE_HTTPS", "value": "${PHOTON_API_USE_HTTPS}" },
        { "key": "GEOAPIFY_API_KEY", "value": "${GEOAPIFY_API_KEY}" },
        { "key": "NOMINATIM_API_HOST", "value": "${NOMINATIM_API_HOST}" },
        { "key": "NOMINATIM_API_KEY", "value": "${NOMINATIM_API_KEY}" },
        { "key": "NOMINATIM_API_USE_HTTPS", "value": "${NOMINATIM_API_USE_HTTPS}" }
      ],
      "dependsOn": ["dawarich_db", "dawarich_redis"]
    },
    {
      "name": "dawarich_sidekiq",
      "image": "freikin/dawarich:1.3.1",
      "isMain": false,
      "entrypoint": "sidekiq-entrypoint.sh",
      "command": ["sidekiq"],
      "stdinOpen": true,
      "tty": true,
      "environment": [
        { "key": "RAILS_ENV", "value": "production" },
        { "key": "REDIS_URL", "value": "redis://dawarich_redis:6379" },
        { "key": "DATABASE_HOST", "value": "dawarich_db" },
        { "key": "DATABASE_PORT", "value": "5432" },
        { "key": "DATABASE_USERNAME", "value": "postgres" },
        { "key": "DATABASE_PASSWORD", "value": "${POSTGRES_PASSWORD}" },
        { "key": "DATABASE_NAME", "value": "dawarich_production" },
        { "key": "APPLICATION_HOSTS", "value": "${APP_DOMAIN},${APP_LOCAL_DOMAIN},${APP_HOST}:${APP_PORT}" },
        { "key": "BACKGROUND_PROCESSING_CONCURRENCY", "value": "10" },
        { "key": "APPLICATION_PROTOCOL", "value": "http" },
        { "key": "SECRET_KEY_BASE", "value": "${SECRET_KEY_BASE}" },
        { "key": "RAILS_LOG_TO_STDOUT", "value": "true" },
        { "key": "SELF_HOSTED", "value": "true" },
        { "key": "STORE_GEODATA", "value": "true" },
        { "key": "PHOTON_API_HOST", "value": "${PHOTON_API_HOST}" },
        { "key": "PHOTON_API_KEY", "value": "${PHOTON_API_KEY}" },
        { "key": "PHOTON_API_USE_HTTPS", "value": "${PHOTON_API_USE_HTTPS}" },
        { "key": "GEOAPIFY_API_KEY", "value": "${GEOAPIFY_API_KEY}" },
        { "key": "NOMINATIM_API_HOST", "value": "${NOMINATIM_API_HOST}" },
        { "key": "NOMINATIM_API_KEY", "value": "${NOMINATIM_API_KEY}" },
        { "key": "NOMINATIM_API_USE_HTTPS", "value": "${NOMINATIM_API_USE_HTTPS}" }
      ],
      "dependsOn": ["dawarich_db", "dawarich_redis", "dawarich_app"]
    }
  ]
}
